generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  INSTRUCTOR
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

// ─── Auth (Better Auth) ─────────────────────────────────────────────────────

model Instructor {
  id            String    @id
  email         String    @unique
  emailVerified Boolean   @default(false)
  name          String
  avatarUrl     String?
  role          Role      @default(INSTRUCTOR)
  banned        Boolean?  @default(false)
  banReason     String?
  banExpires    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions     Session[]
  accounts     Account[]
  invitations  Invitation[] @relation("InvitedBy")

  exercises          Exercise[]
  exerciseFolders    ExerciseFolder[]
  dropdownOptions    DropdownOption[]
  classPlanFolders   ClassPlanFolder[]
  classPlanTemplates ClassPlanTemplate[]
  classes            Class[]
  classInstances     ClassInstance[]
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user Instructor @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user Instructor @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt
}

// ─── Admin ──────────────────────────────────────────────────────────────────

model Invitation {
  id          String           @id @default(cuid())
  email       String
  role        Role             @default(INSTRUCTOR)
  token       String           @unique @default(cuid())
  invitedById String
  invitedBy   Instructor       @relation("InvitedBy", fields: [invitedById], references: [id])
  status      InvitationStatus @default(PENDING)
  expiresAt   DateTime
  createdAt   DateTime         @default(now())

  @@index([token])
  @@index([email])
}

model PlatformSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}


// ─── Exercise Library ────────────────────────────────────────────────────────

model ExerciseFolder {
  id           String    @id @default(cuid())
  name         String
  instructorId String
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?

  instructor Instructor @relation(fields: [instructorId], references: [id])
  exercises  Exercise[]

  @@index([instructorId])
}

model Exercise {
  id               String    @id @default(cuid())
  name             String
  description      String?
  startingPosition String?
  orientation      String?
  directionFaced   String?
  movementType     String?
  springs          String?
  equipment        String[]  @default([])
  machineSetup     String?
  transitionCues   String?
  cueing           String?
  spinalMovement   String[]  @default([])
  chainType        String[]  @default([])
  jointLoading     String[]  @default([])
  tags             String[]  @default([])
  progressionNotes String?
  regressionNotes  String?
  folderId         String?
  instructorId     String
  progressionOfId  String?
  savedToLibrary   Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  instructor           Instructor              @relation(fields: [instructorId], references: [id])
  folder               ExerciseFolder?         @relation(fields: [folderId], references: [id])
  progressionOf        Exercise?               @relation("ExerciseProgression", fields: [progressionOfId], references: [id])
  progressions         Exercise[]              @relation("ExerciseProgression")
  images               ExerciseImage[]
  layers               ExerciseLayer[]
  planSectionExercises PlanSectionExercise[]

  @@index([instructorId])
  @@index([folderId])
}

model ExerciseLayer {
  id         String   @id @default(cuid())
  exerciseId String
  order      Int      @default(0)
  content    String
  isFinisher Boolean  @default(false)
  createdAt  DateTime @default(now())

  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([exerciseId])
}

model DropdownCategory {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  createdAt DateTime @default(now())

  options DropdownOption[]
}

model DropdownOption {
  id           String   @id @default(cuid())
  categoryId   String
  label        String
  value        String
  order        Int      @default(0)
  instructorId String?
  createdAt    DateTime @default(now())

  category   DropdownCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  instructor Instructor?      @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@index([instructorId])
}

model ExerciseImage {
  id         String @id @default(cuid())
  exerciseId String
  url        String
  publicId   String?
  order      Int    @default(0)

  exercise Exercise @relation(fields: [exerciseId], references: [id])

  @@index([exerciseId])
}

// ─── Class Plan Templates ────────────────────────────────────────────────────

model ClassPlanFolder {
  id           String    @id @default(cuid())
  name         String
  instructorId String
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?

  instructor Instructor          @relation(fields: [instructorId], references: [id])
  templates  ClassPlanTemplate[]

  @@index([instructorId])
}

model ClassPlanTemplate {
  id              String    @id @default(cuid())
  name            String
  classType       String?
  classStyle      String?
  durationMinutes Int?
  folderId        String?
  tags            String[]  @default([])
  instructorId    String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  instructor Instructor        @relation(fields: [instructorId], references: [id])
  folder     ClassPlanFolder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)
  sections   PlanSection[]
  classInstances ClassInstance[]
  classes        Class[]

  @@index([instructorId])
  @@index([folderId])
}

model PlanSection {
  id              String   @id @default(cuid())
  name            String
  order           Int      @default(0)
  templateId      String?
  classInstanceId String?
  createdAt       DateTime @default(now())

  template      ClassPlanTemplate? @relation(fields: [templateId], references: [id], onDelete: Cascade)
  classInstance ClassInstance?   @relation(fields: [classInstanceId], references: [id], onDelete: Cascade)
  exercises     PlanSectionExercise[]

  @@index([templateId])
  @@index([classInstanceId])
}

model PlanSectionExercise {
  id         String  @id @default(cuid())
  sectionId  String
  exerciseId String
  order      Int     @default(0)
  reps       String?
  duration   String?
  notes      String?

  section  PlanSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  exercise Exercise    @relation(fields: [exerciseId], references: [id])

  @@index([sectionId])
  @@index([exerciseId])
}

// ─── Calendar & Scheduling ───────────────────────────────────────────────────

enum ClassType {
  GROUP
  PRIVATE
}

enum InstanceStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

model Class {
  id               String    @id @default(cuid())
  title            String
  type             ClassType @default(GROUP)
  isRecurring      Boolean   @default(false)
  recurrenceRule   Json?
  startDate        DateTime
  endDate          DateTime?
  time             DateTime @db.Timestamptz()
  durationMinutes  Int       @default(60)
  templateId       String?
  syncWithTemplate Boolean   @default(false)
  instructorId     String
  createdAt        DateTime  @default(now())
  deletedAt        DateTime?

  instructor Instructor          @relation(fields: [instructorId], references: [id])
  template   ClassPlanTemplate?   @relation(fields: [templateId], references: [id], onDelete: SetNull)
  instances  ClassInstance[]

  @@index([instructorId])
  @@index([templateId])
  @@index([startDate])
}

model ClassInstance {
  id              String         @id @default(cuid())
  classId         String
  date            DateTime       @db.Date
  time            DateTime       @db.Timestamptz()
  status          InstanceStatus @default(SCHEDULED)
  instructorId    String
  templateId      String?
  isCustomised    Boolean        @default(false)
  classType       String?
  classStyle      String?
  rating          Int?
  reflectionNotes String?
  reviewedAt      DateTime?
  createdAt       DateTime       @default(now())
  deletedAt       DateTime?

  class      Class              @relation(fields: [classId], references: [id], onDelete: Cascade)
  instructor Instructor         @relation(fields: [instructorId], references: [id])
  template   ClassPlanTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  sections   PlanSection[]

  @@index([classId])
  @@index([instructorId])
  @@index([date])
  @@index([templateId])
}
